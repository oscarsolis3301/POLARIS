#!/usr/bin/env bash
# POLARIS v5 — board CLI. Pure bash + git. No other dependencies.
# Every board mutation goes through this script. Manual fallback: ops/MANUAL.md
# Bash >= 3.2 (macOS default) compatible: no mapfile, no assoc arrays.
set -eu
POLARIS_V=5

# --- lib loader: every function body lives in lib/ — fixed order, core first ---
OPS_DIR="$(cd "$(dirname "$0")" && pwd)"
for _m in core ownership builder integrate knowledge observe admin \
          selftest/spine selftest/board selftest/history selftest/report \
          selftest/brain selftest/policy selftest/remote; do
  if [ ! -f "$OPS_DIR/lib/$_m.sh" ]; then
    printf '⛔ POLARIS: ops/lib/%s.sh is missing — this kit is incomplete. Re-run the installer (bash ops/install.sh) or fetch a fresh kit: ops/polaris update\n' "$_m" >&2
    exit 1
  fi
  . "$OPS_DIR/lib/$_m.sh"
done
unset _m

git rev-parse --git-dir >/dev/null 2>&1 || die "not inside a git repo"

# ---------------------------------------------------------------- resolve env
GCD="$(cd "$(git rev-parse --git-common-dir)" && pwd)"     # shared across all worktrees
PRIMARY="$(git worktree list --porcelain | sed -n '1s/^worktree //p')"
[ -n "$PRIMARY" ] || die "cannot resolve primary checkout"
OPS="$PRIMARY/ops"
BOARD="$OPS/board"
LOCKS="$GCD/polaris-locks"
CONV="$OPS/CONVENTIONS.md"
VER="$OPS/VERSION"
SELF="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
BASE="$(cfg base main)"
CLAIM_MODE="$(cfg claim local-lock)"
STALE_H="$(cfg stale_hours 4)"
WHO="${USER:-${USERNAME:-unknown}}@$(hostname 2>/dev/null || echo host)"
EVENTS="$BOARD/EVENTS.ndjson"

RULES="$OPS/RULES.tsv"
MUTEX="$LOCKS/.board-mutex"
FAIL_LOCK_ID=""
PUB="direct"
PUBLISH_WARNED=""
BOARD_REF="refs/heads/polaris/board"

# ------------------------------------------------------------------- dispatch
usage() { cat <<'EOF'
polaris — POLARIS board CLI (run from anywhere inside the repo)
  init-board                     create board dirs, gitignore .polaris/ + the board set, lock dir
                                 (board state commits to refs/heads/polaris/board — base stays clean)
  claim [ID]                     lock + ready→active + worktree  (no ID = top wsjf; skips locked)
  resume [ID]                    re-enter an already-claimed active task (crash/kickback/new session)
  verify [ID]                    diff ⊆ files_owned + run verify: commands (in worktree)
  handoff [ID]                   verify + push + active→review   (lock stays)
  release <ID> [--to ready|blocked] [-m note]   abort: give the task back cleanly
  grant <ID> <path> -m "why"     append one path to a CLAIMED task's files_owned (sanctioned
                                 amendment; REFUSES any overlap with another ready/active task's
                                 ownership — refusal mutates nothing; RULES.tsv still binds)
  kickback <ID> [-m note]        Integrator: red merge → review→active
  audit <ID>                     Integrator: ownership check of feat/<ID>
  run-verify <ID>                Integrator: re-run task verify: commands in CWD
  done <ID>                      Integrator: review→done + map_delta as docs(map): on base + cleanup
  task-commit-msg <task-file>    print the task's landed-commit message (pure; `land` consumes it)
  land <ID>                      Integrator, on integrate/<date>: audit + squash feat/<ID> into
                                 ONE rich commit ([<ID>] subject + Landed-from trailer; no board write)
  land --express <ID>            ONE pass for a single small task, from <base>: integrate branch +
                                 audit/land + ONE full suite (red → unwind + kickback) + seal +
                                 run-verify + done + branch cleanup. Refuses: another task in
                                 review/ · risk: high · express: off · publish: pr. Every gate of
                                 the long path still runs; `qa` stays the finish line.
  seal [<date>]                  Integrator: seal the wave — merge integrate/<date> into base
                                 (--no-ff, per-task bullets) + lightweight tag sprint/<n>; a later
                                 wave's seal MOVES the tag (sprint's latest sealed checkpoint).
                                 publish: pr (CONVENTIONS key, default direct): NO local merge —
                                 pushes ONLY integrate/<date> + prints the PR-create URL
  seal --sync [<date>]           publish: pr only — finish the wave after the human merges the PR
                                 (MERGE COMMIT strategy, never squash): verify every [<ID>] subject
                                 reached base, tag sprint/<n>, delete integrate/<date> local+remote
  report [--sprint <n> | --all]  render the management-readable per-sprint record (docs/sprints/
                                 by default) from the board + history; writes the file(s), prints
                                 the path(s), commits nothing (seal commits it on the wave instead)
  history [--tasks <n>]          changelog view of base (board noise hidden); --tasks <n> drills
                                 into one sealed sprint's task commits, across all its waves
  rollback <ID|sprint/<n>>       revert one landed task (or the sprint's latest sealed wave, -m 1)
                                 on base — forward-only: never resets, never force-pushes
  status [--brief] | sweep [--fix] | doctor [--selftest [--only <patterns>] [--parallel <N>]]
                                 status --brief = ONE plain-English paragraph, no table (plain status
                                 unchanged): Last landed: / Next up: markers + a sprint-column clause
                                 doctor --selftest --only <patterns> = the always-on spine + only the
                                 labeled drills matching any comma-separated glob (fmlist tcm report
                                 metrics brain rules drift hardening qa remote syncrace notify grant
                                 upgrade pr-publish express hint brief); a nonsense element dies
                                 before the spine (unknown drill label); --parallel <N> = run the
                                 selected drills as N parallel child shards (serial stays the default)
  brain [--refresh]              generate .polaris/brain/ — gitignored knowledge base a cold agent
                                 reads FIRST (INDEX + code-map/board/contracts/commands/gotchas);
                                 --refresh skips code-map when code is unchanged. seal auto-refreshes
                                 an existing brain; doctor warns when it is stale
  metrics                        opens with a plain-English summary line, then cycle · throughput ·
                                 kickbacks · build-vs-integrate split (EVENTS.ndjson)
  why <ID>                       why a task bounced/blocked: kickback + release/blocked notes from telemetry + body
  notify-gate <kind> [ID]        fire the notify: hook at a human gate, and nothing else — kinds:
                                 plan · risk <ID> · question <ID> · done [ID]  (observe-only:
                                 never writes the board, EVENTS.ndjson, or any lock)
  drift [--strict]               mechanical board-hygiene audit (overlap · ready gate · cruft · stale refs)
  rules                          list + health-check ops/RULES.tsv (repo policy as data)
  qa                             is everything okay, in ONE shot: test/lint/typecheck/build/uat
                                 from CONVENTIONS + drift --strict + doctor env check. Runs every
                                 check even after a red; rc 1 if anything was red.
  dash [--port N]                live read-only board at http://127.0.0.1:7373 (needs python3)
  fleet <N> [--loop] [--launch] [--dry-run]
                                 print N Builder kickoffs; --launch opens a session per task in
                                 tmux windows or Windows Terminal panes (--dry-run previews the command)
  upgrade                        migrate an OLD BOARD (v3/v4→v5). Idempotent. Downloads NOTHING.
                                   want a newer KIT? that is `update` — one letter, unrelated job.
  version                        installed version · commit · latest on the channel
  update [--repo-only]           fetch the latest KIT from the channel (manual; never automatic).
                                   also re-caches it into ~/.claude so the NEXT repo you install
                                   into gets the new kit too. --repo-only skips that.
  uninstall --yes                remove POLARIS from this repo (keeps your CLAUDE.md + hooks)
EOF
}
# update_check_maybe is wired ONLY into the human-facing commands below — deliberately not
# into _match/_rules, which the write-guard fires on every single edit.
case "${1:-}" in
  init-board) cmd_init_board;;
  claim)      shift; update_check_maybe || true; cmd_claim "$@";;
  resume)     shift; cmd_resume "$@";;
  verify)     shift; cmd_verify "$@";;
  handoff)    shift; cmd_handoff "$@";;
  release)    shift; cmd_release "$@";;
  grant)      shift; cmd_grant "$@";;
  kickback)   shift; cmd_kickback "$@";;
  audit)      shift; cmd_audit "$@";;
  run-verify) shift; cmd_run_verify "$@";;
  done)       shift; cmd_done "$@";;
  task-commit-msg) shift; cmd_task_commit_msg "$@";;
  land)       shift; cmd_land "$@";;
  seal)       shift; cmd_seal "$@";;
  history)    shift; cmd_history "$@";;
  report)     shift; cmd_report "$@";;
  rollback)   shift; cmd_rollback "$@";;
  status)     shift 2>/dev/null || true; update_check_maybe || true; cmd_status "${1:-}";;
  brain)      shift 2>/dev/null || true; cmd_brain "${1:-}";;   # no update_check_maybe: agents run it cold and often — keep it quiet + pure
  sweep)      shift 2>/dev/null || true; cmd_sweep "${1:-}";;
  doctor)     shift 2>/dev/null || true; update_check_maybe || true; cmd_doctor "$@";;
  metrics)    cmd_metrics;;
  why)        shift; cmd_why "$@";;
  drift)      shift 2>/dev/null || true; cmd_drift "${1:-}";;
  rules)      cmd_rules;;
  qa)         cmd_qa;;
  notify-gate) shift; cmd_notify_gate "$@";;   # no update_check_maybe: must stay silent + pure
  _rules)     shift; cmd_rules_check "$@";;
  dash)       shift; update_check_maybe || true; cmd_dash "$@";;
  fleet)      shift; cmd_fleet "$@";;
  upgrade)    cmd_upgrade;;
  version)    update_check_maybe force || true; cmd_version;;
  update)     shift; cmd_update "${1:-}";;
  uninstall)  shift; cmd_uninstall "$@";;
  _match)     shift; cmd_match "$@";;
  ''|help|-h|--help) usage;;
  *) usage; die "unknown command: $1";;
esac
