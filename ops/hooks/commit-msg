#!/bin/sh
# POLARIS commit-msg hook — the product carries no AI fingerprints.
# Strips AI-provider attribution lines from every commit message, whichever tool wrote them:
#   Co-Authored-By: Claude … <noreply@anthropic.com> / Copilot / Cursor / …   (bot co-authors)
#   🤖 Generated with [Claude Code](…) · Generated by <ai tool> …             (badge lines)
# Human Co-Authored-By trailers are untouched. It cleans, it never blocks: exit is always 0.
# Installed into $GIT_DIR/hooks/ by ops/install.sh (worktrees share it); `polaris doctor`
# re-installs it when missing. Source of truth: ops/hooks/commit-msg.
MSG="$1"
[ -n "$MSG" ] && [ -f "$MSG" ] || exit 0

# ERE fragment: names/emails that identify an AI tool on an attribution line. A line is only
# dropped when it is BOTH an attribution line (Co-Authored-By / Generated with|by) AND names
# one of these — "Generated by the build script" or a human co-author passes untouched.
AI='claude|anthropic|copilot|cursor|codex|chatgpt|openai|gemini|devin|aider|windsurf|\[bot\]|noreply@|ruv@ruv\.net'

TMP="$MSG.polaris"
grep -viE "^[[:space:]]*(🤖[[:space:]]*)?(co-authored-by:.*(${AI})|generated[- ](with|by).*(${AI}))" \
  "$MSG" > "$TMP" 2>/dev/null || true
# Drop the blank lines a stripped trailer block leaves at the end.
awk '{ line[NR]=$0; if ($0 ~ /[^[:space:]]/) last=NR } END { for (i=1; i<=last; i++) print line[i] }' \
  "$TMP" > "$MSG" 2>/dev/null || true
rm -f "$TMP"
exit 0
