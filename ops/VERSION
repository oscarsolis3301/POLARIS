# POLARIS kit version + update channel. Machine-read by `ops/polaris version|update`.
# The comparison key is `version:` — a semver bump here is what notifies installed kits.
# Routine commits to main do NOT nag anyone; only an intentional bump does.
version: 5.5.0
channel: https://raw.githubusercontent.com/oscarsolis3301/POLARIS/main/ops/VERSION
changelog: https://github.com/oscarsolis3301/POLARIS/blob/main/CHANGELOG.md
tarball: https://codeload.github.com/oscarsolis3301/POLARIS/tar.gz/refs/heads/main
repo: https://github.com/oscarsolis3301/POLARIS.git
# `zip:` is the PUBLISHED release artifact — the same pinned URL the installer's permission rule
# names. `update` re-caches it into ~/.claude/skills/polaris-install/ so that updating ONE repo
# also updates the machine, and the next fresh install can't lay down a stale kit.
zip: https://github.com/oscarsolis3301/POLARIS/releases/latest/download/polaris-v5.zip
# `commit:` and `built:` are appended by ops/pack.py (into the zip) and by ops/install.sh
# (into the target) — never committed here, or stamping the sha would change the sha.
